{
  "title": "Maturity Score",
  "uid": "maturity-score-v1",
  "schemaVersion": 38,
  "refresh": "30s",
  "tags": [
    "sre",
    "maturity"
  ],
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "area",
        "label": "\u00c1rea",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(maturity_score, area)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      },
      {
        "name": "team",
        "label": "Time",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(maturity_score{area=~\"$area\"}, team)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 11,
      "title": "Score por Scorecard \u2014 M\u00e9dia por \u00c1rea",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "round(maturity:area_scorecard_score{area=~\"$area\"}, 0.1)",
          "legendFormat": "{{area}} \u2014 {{scorecard}}",
          "instant": true
        }
      ]
    },
